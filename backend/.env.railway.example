# Required runtime variables for Railway
# Use either ConnectionStrings__DefaultConnection OR DATABASE_URL
ConnectionStrings__DefaultConnection=Host=YOUR_HOST;Port=5432;Database=postgres;Username=YOUR_USERNAME;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require

# Use either Supabase__Url OR SUPABASE_URL
Supabase__Url=https://YOUR_PROJECT.supabase.co
# SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Optional: set multiple origins by index
AllowedOrigins__0=https://arch-automate.netlify.app
# AllowedOrigins__1=http://localhost:5289
